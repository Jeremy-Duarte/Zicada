# ============================================
# DJANGO SETTINGS
# ============================================
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE (elige una opción)
# ============================================
# Opción 1: SQLite (desarrollo local)
DATABASE_URL=sqlite:///db.sqlite3

# Opción 2: PostgreSQL (producción)
# DATABASE_URL=postgres://usuario:contraseña@localhost:5432/zicada_db

# Opción 3: MySQL
# DATABASE_URL=mysql://usuario:contraseña@localhost:3306/zicada_db

# ============================================
# EMAIL SETTINGS
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=aaaa aaaa aaaa aaaa
DEFAULT_FROM_EMAIL=Zicada <tu_correo@gmail.com>

# Emails personalizados por función
FROM_EMAIL_NO_REPLY=Zicada <noreply@zicada.com>
FROM_EMAIL_ORDERS=Zicada Pedidos <pedidos@zicada.com>
FROM_EMAIL_SUPPORT=Zicada Soporte <soporte@zicada.com>